{
  "name": "ggmu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "tsx watch backend/src/server.ts",
    "build:frontend": "tsc -b frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:server": "npm run build:backend",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "node dist/backend/server.js",
    "preview": "vite preview --config frontend/vite.config.ts",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "sync:season": "tsx backend/src/scripts/firstSync.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^4.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "tsx": "^4.19.3",
    "vite": "^5.4.8"
  }
}
