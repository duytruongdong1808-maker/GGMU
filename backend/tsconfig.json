{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../dist/backend",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": [
    "src/app.ts",
    "src/server.ts",
    "src/config/**/*.ts",
    "src/modules/**/*.ts",
    "src/integrations/**/*.ts",
    "src/lib/asyncHandler.ts",
    "src/lib/httpError.ts",
    "src/lib/logger.ts",
    "src/lib/prisma.ts",
    "src/jobs/**/*.ts",
    "src/middleware/**/*.ts",
    "src/scripts/**/*.ts",
    "src/utils/apiResponse.ts",
    "src/utils/date.ts",
    "src/utils/pagination.ts"
  ],
  "exclude": ["../dist", "../node_modules"]
}
