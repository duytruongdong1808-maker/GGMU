NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ggmu_backend?schema=public
FRONTEND_ORIGIN=http://localhost:5173
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=your_football_data_token
FOOTBALL_DATA_TEAM_ID=66

# Set to apisports for a direct API-SPORTS subscription or rapidapi for RapidAPI.
FOOTBALL_API_PROVIDER=apisports
# API-SPORTS direct example: https://v3.football.api-sports.io
# RapidAPI example: https://api-football-v1.p.rapidapi.com/v3
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=your_api_football_key
# API-SPORTS direct host: v3.football.api-sports.io
# RapidAPI host: api-football-v1.p.rapidapi.com
FOOTBALL_API_HOST=v3.football.api-sports.io
FOOTBALL_API_TIMEOUT_MS=15000
FOOTBALL_API_RATE_LIMIT_MS=350
FOOTBALL_API_RETRY_COUNT=3

MANCHESTER_UNITED_TEAM_ID=33
MATCH_SYNC_CRON=0 3,15 * * *
MATCH_SYNC_ENABLED=true
# Required for POST /api/sync/matches. Send as X-Sync-Secret or Authorization: Bearer <secret>.
MATCH_SYNC_TRIGGER_SECRET=replace_with_a_long_random_secret
MATCH_SYNC_ROUTE_RATE_LIMIT_WINDOW_MS=900000
MATCH_SYNC_ROUTE_RATE_LIMIT_MAX=3
